# === LLM ===
GROQ_API_KEY=your_groq_api_key_here

# === Search ===
SERPER_API_KEY=your_serper_api_key_here

# === GitHub ===
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=yourusername/jarvis

# === Google APIs ===
# Download credentials.json from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Enable Gmail API + Google Calendar API
# 3. Create OAuth 2.0 Desktop Client credentials
# 4. Download as credentials.json in project root
GOOGLE_CREDENTIALS_FILE=credentials.json

# === Mem0 (optional — uses local vector store by default) ===
# MEM0_API_KEY=your_mem0_cloud_key_here  # Only needed for Mem0 Cloud
